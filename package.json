  "description": "A cinematic Joseon zombie visual-novel demo built with React, TypeScript, and Vite.",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/MovieHolic-Plex/chosun-zombie.git"
  },
  "bugs": {
    "url": "https://github.com/MovieHolic-Plex/chosun-zombie/issues"
  },
